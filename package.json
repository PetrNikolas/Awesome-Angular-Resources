    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.3",
    "@angular/language-service": "^22.0.3",
    "@types/jasmine": "~2.8.6",
    "@types/jasminewd2": "~2.0.3",
    "@types/mocha": "5.2.7",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
