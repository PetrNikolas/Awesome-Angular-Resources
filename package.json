{
  "name": "awesome-angular-resources",
  "version": "1.0.5",
  "scripts": {
    "ng": "ng",
    "build": "yarn ng build",
    "build-prod": "yarn ng build --configuration production",
    "ci": "yarn format:write && yarn format:fix && yarn lint && yarn test",
    "e2e": "yarn ng e2e",
    "format:write": "prettier --config './.prettierrc' {src,e2e}/**/*.{ts,json,md,scss} --write",
    "format:fix": "pretty-quick --staged",
    "lint": "yarn ng lint",
    "start": "yarn ng serve",
    "test": "yarn ng test"
  },
  "private": true,
  "dependencies": {
