{
  "name": "awesome-angular-resources",
  "version": "1.0.5",
  "scripts": {
    "ng": "ng",
    "build": "yarn ng build",
    "build-prod": "yarn ng build --configuration production",
    "ci": "yarn format:write && yarn format:fix && yarn lint && yarn test",
    "e2e": "playwright test",
    "format:write": "prettier --config './.prettierrc' {src,e2e}/**/*.{ts,json,md,scss} --write",
    "format:fix": "pretty-quick --staged",
    "lint": "yarn ng lint",
    "start": "yarn ng serve",
    "test": "jest"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/pwa": "22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "animate.css": "^4.1.1",
    "classlist.js": "^1.1.20150312",
    "core-js": "^3.49.0",
    "rxjs": "^7.8.2",
    "web-animations-js": "^2.3.1",
    "zone.js": "^0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.0",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-service": "^22.0.0",
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "husky": "^9.0.0",
    "jest": "^30.0.0",
    "jest-preset-angular": "^17.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.3.0",
    "pretty-quick": "^4.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "~5.0.1",
    "typescript": "^6.0.0"
  }
}
